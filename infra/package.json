{
  "name": "ip6original-infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "infra": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "diff:staging": "cdk diff Ip6StagingStack",
    "diff:prod": "cdk diff Ip6ProdStack",
    "deploy:staging": "cdk deploy Ip6StagingStack --require-approval never",
    "deploy:prod": "cdk deploy Ip6ProdStack --require-approval broadening"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.155.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "aws-cdk": "^2.155.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
