# =========================
# Site
# =========================
NEXT_PUBLIC_SITE_URL=https://ip6original.com
NEXT_PUBLIC_SITE_NAME="IP-6 Research, Inc."
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fr,de,hi
NEXT_PUBLIC_NSF_CERTIFIED=false

# Comma-separated ISO-3166-1 alpha-2 codes permitted for supplement + skincare shipping
